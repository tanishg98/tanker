.DS_Store
.cursor/
*.local.json
*.env
node_modules/

# Python bytecode caches (brain-index uses chromadb)
__pycache__/
*.pyc

# Runtime lock files
.claude/scheduled_tasks.lock

# User-local Claude Code settings (hooks are opt-in per machine)
.claude/settings.json
.claude/settings.local.json

# Overnight runner state (per-machine)
.claude/hooks/.session-counter

# Project-specific brain (sensitive — never tracked)
.claude/brain.private.md
.claude/projects/

# Skill output artifacts (per-project working files, never public)
outputs/
